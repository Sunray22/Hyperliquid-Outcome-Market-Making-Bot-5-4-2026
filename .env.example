# Copy to .env and fill in. The bot auto-loads .env from the working
# directory at startup (point it elsewhere with HL_OMM_DOTENV=/path/to/file).
# Anything starting with HL_OMM__ is read by the layered config loader and
# overrides config/default.toml — the double underscore is a section separator
# (e.g. HL_OMM__VENUES__HYPERLIQUID_PK -> [venues].hyperliquid_pk).

HL_OMM_CONFIG=config/default.toml
HL_OMM__NETWORK__IS_MAINNET=true

# Hyperliquid signer (one EOA controls perp + spot + outcome).
HL_OMM__VENUES__HYPERLIQUID_PK=0xreplace_me
# HL_OMM__VENUES__HYPERLIQUID_VAULT=0x_optional_vault_address

# Polymarket — derived API triple from CLOB_API_GENERATE_OR_GET_API_KEY().
# HL_OMM__VENUES__POLYMARKET_KEY=
# HL_OMM__VENUES__POLYMARKET_SECRET=
# HL_OMM__VENUES__POLYMARKET_PASSPHRASE=
# HL_OMM__VENUES__POLYMARKET_MAKER=0x...

# Kalshi
# HL_OMM__VENUES__KALSHI_KEY_ID=...
# HL_OMM__VENUES__KALSHI_PEM_PATH=./config/kalshi.pem
# HL_OMM__VENUES__KALSHI_WS_TOKEN=eyJhbGciOiJSUzI1NiIs...

RUST_LOG=hl_omm=info,info
